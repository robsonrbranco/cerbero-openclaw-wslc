# Copie para ".env" (sem .example) e preencha. NÃO commitar este arquivo com valores reais.

# --- Provedores de modelo (API key) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Gateway ---
# Gere um valor aleatório forte, ex.: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=troque-por-um-token-aleatorio-forte

# --- gog (Google Workspace CLI, opcional) ---
# Senha do keyring que protege as credenciais OAuth do gog. Gere um valor
# aleatório forte, ex.: openssl rand -hex 12
GOG_KEYRING_PASSWORD=troque-por-uma-senha-aleatoria-forte
